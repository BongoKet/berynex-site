---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Message Received — Berynex">

  <div class="min-h-screen flex items-center justify-center px-6 pt-16">
    <div class="max-w-md mx-auto text-center">

      <div class="w-16 h-16 rounded border border-[#1a2d48] bg-[#0a1120] flex items-center justify-center mx-auto mb-8">
        <svg width="28" height="28" fill="none" stroke="#1e6fe8" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.8rem;color:#eef2f8;" class="mb-3">
        Message received
      </h1>
      <p class="text-[#8496b0] leading-relaxed mb-2">
        Thank you for getting in touch. We will review your message and respond shortly.
      </p>
      <p class="text-sm text-[#3a5070] mb-10">
        For urgent matters, email
        <a href="mailto:contact@berynex.com" class="text-[#1e6fe8] hover:text-white transition-colors">contact@berynex.com</a> directly.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="w-full sm:w-auto px-6 py-2.5 rounded bg-[#1e6fe8] hover:bg-[#155dc4] text-white text-sm font-semibold transition-colors">
          Back to Home
        </a>
        <a href="/projects" class="w-full sm:w-auto px-6 py-2.5 rounded border border-[#1a2d48] hover:border-[#243d60] text-[#8496b0] hover:text-white text-sm font-semibold transition-all">
          View Projects
        </a>
      </div>

    </div>
  </div>

</Layout>
