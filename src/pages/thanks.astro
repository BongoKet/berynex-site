---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Message Received — Berynex" description="Thank you for contacting Berynex.">

  <div class="min-h-screen flex items-center justify-center px-6 pt-20">
    <div class="max-w-lg mx-auto text-center">

      <!-- Icon -->
      <div class="w-20 h-20 rounded-full bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] flex items-center justify-center text-4xl mx-auto mb-8 glow-blue">
        ✓
      </div>

      <h1 class="font-['Space_Grotesk',sans-serif] text-3xl sm:text-4xl font-bold text-white mb-4">
        Message received
      </h1>

      <p class="text-[#8892a4] leading-relaxed mb-3">
        Thank you for getting in touch. We'll review your message and get back to you shortly.
      </p>
      <p class="text-[#5a6580] text-sm mb-10">
        If your enquiry is urgent, you can also reach us directly at
        <a href="mailto:contact@berynex.com" class="text-[#4f8ef7] hover:text-white transition-colors">contact@berynex.com</a>.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/"
           class="w-full sm:w-auto px-7 py-3 rounded-full bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white font-semibold text-sm hover:opacity-90 transition-opacity">
          Back to Home
        </a>
        <a href="/projects"
           class="w-full sm:w-auto px-7 py-3 rounded-full border border-[#1e2a4a] text-[#8892a4] font-semibold text-sm hover:border-[#4f8ef7] hover:text-white transition-all">
          View Projects
        </a>
      </div>

    </div>
  </div>

</Layout>
