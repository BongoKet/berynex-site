---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryColour: Record<string, string> = {
  AI:         'text-[#60a5fa] border-[#1a2d48] bg-[#0c1528]',
  Legal:      'text-[#a78bfa] border-[#1a2d48] bg-[#110c28]',
  Technology: 'text-[#34d399] border-[#1a2d48] bg-[#0c1e18]',
  Business:   'text-[#fbbf24] border-[#1a2d48] bg-[#1a150c]',
  Tips:       'text-[#f87171] border-[#1a2d48] bg-[#1a0c0c]',
};
---

<Layout
  title="Insights — Berynex"
  description="Articles on AI, legal technology, and practical guides for businesses from the Berynex team."
>

  <div class="pt-28 pb-24 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="mb-14 max-w-2xl">
        <div class="accent-line"></div>
        <h1 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(2rem,4vw,3rem);color:#eef2f8;line-height:1.1;" class="mb-4">
          Insights
        </h1>
        <p class="text-[#8496b0] leading-relaxed">
          Practical guides and perspectives on AI, technology, and legal innovation — written for business owners, professionals, and anyone curious about where these fields are heading.
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="border border-dashed border-[#1a2d48] rounded-xl p-12 text-center">
          <p class="text-[#3a5070] text-sm">Articles coming soon.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map(post => (
            <a href={`/blog/${post.id}`} class="fade-up card p-6 flex flex-col group">
              <div class="flex items-center justify-between mb-4">
                <span class={`text-xs font-semibold border px-2.5 py-0.5 rounded ${categoryColour[post.data.category] ?? 'text-[#8496b0] border-[#1a2d48] bg-[#0a1120]'}`}>
                  {post.data.category}
                </span>
                <time class="text-xs text-[#3a5070]">
                  {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
              </div>
              <h2 style="font-family:'Space Grotesk',sans-serif;font-weight:600;color:#eef2f8;font-size:1rem;line-height:1.35;" class="mb-2 group-hover:text-[#1e6fe8] transition-colors flex-1">
                {post.data.title}
              </h2>
              <p class="text-sm text-[#8496b0] leading-relaxed line-clamp-3 mb-5">
                {post.data.description}
              </p>
              <span class="inline-flex items-center gap-1 text-xs font-semibold text-[#1e6fe8] mt-auto">
                Read article
                <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      )}

    </div>
  </div>

</Layout>
