---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const subject = Astro.url.searchParams.get('subject') ?? 'other';
---

<Layout title="Contact — Berynex" description="Get in touch with Berynex about tech support, LegalAI, Torellio, or any general enquiry.">

  <div class="pt-32 pb-24 px-6">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="mb-12">
        <p class="text-xs text-[#4f8ef7] font-semibold tracking-widest uppercase mb-4">Get in Touch</p>
        <h1 class="font-['Space_Grotesk',sans-serif] text-4xl sm:text-5xl font-bold text-white mb-4">
          Let's talk
        </h1>
        <p class="text-[#8892a4] leading-relaxed max-w-lg">
          Whether you're a solicitor firm exploring AI, a local business needing tech support,
          or a collaborator with an idea &mdash; we'd like to hear from you.
        </p>
      </div>

      <!-- Contact cards -->
      <div class="grid sm:grid-cols-3 gap-4 mb-10">
        <a href="mailto:contact@berynex.com"
           class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-xl p-5 flex flex-col items-center gap-2 group text-center">
          <span class="text-2xl">✉️</span>
          <span class="text-xs text-[#8892a4] group-hover:text-white transition-colors font-medium">Email</span>
          <span class="text-xs text-[#5a6580]">contact@berynex.com</span>
        </a>
        <a href="https://linkedin.com/in/dave7152" target="_blank" rel="noopener"
           class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-xl p-5 flex flex-col items-center gap-2 group text-center">
          <span class="text-2xl">💼</span>
          <span class="text-xs text-[#8892a4] group-hover:text-white transition-colors font-medium">LinkedIn</span>
          <span class="text-xs text-[#5a6580]">linkedin.com/in/dave7152</span>
        </a>
        <div class="border border-[#1e2a4a] bg-[#0f1629]/60 rounded-xl p-5 flex flex-col items-center gap-2 text-center">
          <span class="text-2xl">📍</span>
          <span class="text-xs text-[#8892a4] font-medium">Location</span>
          <span class="text-xs text-[#5a6580]">Llangollen, North Wales</span>
        </div>
      </div>

      <!-- Form -->
      <form
        class="border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-8 backdrop-blur-sm"
        action="https://formspree.io/f/xdabknez"
        method="POST"
      >

        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Name</label>
            <input type="text" name="name" required
                   class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white placeholder-[#4a5568] focus:outline-none focus:border-[#4f8ef7] transition-colors"
                   placeholder="Your name" />
          </div>
          <div>
            <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Email</label>
            <input type="email" name="email" required
                   class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white placeholder-[#4a5568] focus:outline-none focus:border-[#4f8ef7] transition-colors"
                   placeholder="you@example.com" />
          </div>
        </div>

        <div class="mb-4">
          <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Subject</label>
          <select name="subject"
                  class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-[#4f8ef7] transition-colors">
            <option value="legalai" selected={subject === 'legalai'}>LegalAI &mdash; Early Access / Pilot</option>
            <option value="tech" selected={subject === 'tech'}>Tech Support / PC Repair</option>
            <option value="torellio" selected={subject === 'torellio'}>Torellio &mdash; Waitlist / Feedback</option>
            <option value="other" selected={subject === 'other'}>General Enquiry</option>
          </select>
        </div>

        <div class="mb-6">
          <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Message</label>
          <textarea name="message" required rows="5"
                    class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white placeholder-[#4a5568] focus:outline-none focus:border-[#4f8ef7] transition-colors resize-none"
                    placeholder="Tell us what you're working on..."></textarea>
        </div>

        <button type="submit" id="submit-btn"
                class="w-full py-3.5 rounded-xl bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white font-semibold text-sm hover:opacity-90 transition-opacity disabled:opacity-50">
          Send Message
        </button>
      </form>

      <script>
        const form = document.querySelector('form') as HTMLFormElement;
        const btn = document.getElementById('submit-btn') as HTMLButtonElement;
        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          btn.disabled = true;
          btn.textContent = 'Sending...';
          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { Accept: 'application/json' },
            });
            if (res.ok) {
              window.location.href = '/thanks';
            } else {
              btn.disabled = false;
              btn.textContent = 'Send Message';
              alert('Something went wrong. Please try again or email contact@berynex.com directly.');
            }
          } catch {
            btn.disabled = false;
            btn.textContent = 'Send Message';
            alert('Something went wrong. Please try again or email contact@berynex.com directly.');
          }
        });
      </script>

    </div>
  </div>

</Layout>
