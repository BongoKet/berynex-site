---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Projects — Berynex"
  description="Berynex project portfolio: local tech services, AI-powered tools, and legal technology from North Wales."
>

  <div class="pt-28 pb-24 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="mb-14 max-w-2xl">
        <div class="accent-line"></div>
        <h1 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(2rem,4vw,3rem);color:#eef2f8;line-height:1.1;" class="mb-4">
          Projects &amp; Ventures
        </h1>
        <p class="text-[#8496b0] leading-relaxed">
          A growing portfolio of technology projects spanning local services, consumer AI, and professional legal tools &mdash; all built from North Wales.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-6 mb-8">

        <!-- Bongo's Club -->
        <div class="fade-up card p-8 flex flex-col">
          <div class="flex items-start justify-between mb-6">
            <div class="w-12 h-12 rounded bg-[#0f1a30] border border-[#1a2d48] flex items-center justify-center">
              <svg width="22" height="22" fill="none" stroke="#1e6fe8" stroke-width="1.8" viewBox="0 0 24 24">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8M12 17v4"/>
              </svg>
            </div>
            <span class="text-xs font-semibold bg-[#0c1e14] text-[#22c55e] border border-[#1a3a25] px-2.5 py-1 rounded">Live</span>
          </div>

          <h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.4rem;color:#eef2f8;" class="mb-3">Bongo's Club</h2>
          <p class="text-[#8496b0] text-sm leading-relaxed mb-5 flex-1">
            Local PC repair and technical support serving Llangollen, Wrexham, Chirk, Corwen, and surrounding Denbighshire.
            Operating on a no-fix, no-fee basis — with free how-to guides, virus removal, hardware upgrades, and data recovery.
          </p>

          <div class="border-t border-[#1a2d48] pt-5">
            <p class="text-xs text-[#3a5070] uppercase tracking-widest font-semibold mb-3">Services</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {['PC Repair & Diagnostics', 'Virus & Malware Removal', 'Hardware Upgrades', 'Data Recovery', 'Setup & Configuration'].map(s => (
                <span class="text-xs border border-[#1a2d48] text-[#8496b0] px-3 py-1 rounded">{s}</span>
              ))}
            </div>
            <a href="https://bongosclub.uk/" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-sm font-semibold text-[#1e6fe8] hover:text-white transition-colors">
              Visit bongosclub.uk
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Torellio -->
        <div class="fade-up card p-8 flex flex-col">
          <div class="flex items-start justify-between mb-6">
            <div class="w-12 h-12 rounded bg-[#0f1a30] border border-[#1a2d48] flex items-center justify-center">
              <svg width="22" height="22" fill="none" stroke="#1e6fe8" stroke-width="1.8" viewBox="0 0 24 24">
                <path d="M12 2a4 4 0 014 4v1h1a2 2 0 012 2v6a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2h1V6a4 4 0 014-4z"/>
                <circle cx="9" cy="13" r="1" fill="#1e6fe8"/>
                <circle cx="15" cy="13" r="1" fill="#1e6fe8"/>
              </svg>
            </div>
            <span class="text-xs font-semibold bg-[#0c1528] text-[#60a5fa] border border-[#1a2d48] px-2.5 py-1 rounded">Pre-launch</span>
          </div>

          <h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.4rem;color:#eef2f8;" class="mb-3">Torellio</h2>
          <p class="text-[#8496b0] text-sm leading-relaxed mb-5 flex-1">
            An AI-powered shopping assistant that compares products across open browser tabs, scans rooms
            to suggest matching decor, and deploys four collaborative AI agents to deliver personalised
            buying recommendations. Showcased at the AMD Developer Hackathon 2026. Waitlist open.
          </p>

          <div class="border-t border-[#1a2d48] pt-5">
            <p class="text-xs text-[#3a5070] uppercase tracking-widest font-semibold mb-3">Features</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {['Smart Tab Comparison', 'Visual Room Scanner', 'Multi-Agent Research', 'Price Tracking', 'Personalised Picks'].map(s => (
                <span class="text-xs border border-[#1a2d48] text-[#8496b0] px-3 py-1 rounded">{s}</span>
              ))}
            </div>
            <a href="https://torellio.com" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-sm font-semibold text-[#1e6fe8] hover:text-white transition-colors">
              Visit torellio.com
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>

      </div>

      <!-- LegalAI card -->
      <div class="fade-up border border-dashed border-[#1a2d48] rounded-xl p-7 sm:p-9 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 bg-[#0a1120]">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 rounded bg-[#0f1a30] border border-[#1a2d48] flex items-center justify-center">
              <svg width="16" height="16" fill="none" stroke="#1e6fe8" stroke-width="1.8" viewBox="0 0 24 24">
                <path d="M3 6l9-3 9 3M3 6v12l9 3 9-3V6M12 3v18"/>
                <path d="M3 10h18M3 14h18"/>
              </svg>
            </div>
            <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1.15rem;color:#eef2f8;">Berynex LegalAI</h3>
            <span class="text-xs font-semibold bg-[#0c1528] text-[#8496b0] border border-[#1a2d48] px-2.5 py-0.5 rounded">In Development</span>
          </div>
          <p class="text-sm text-[#8496b0] max-w-lg">Private, on-premise AI for solicitor firms. Document drafting, case research, and client communications — entirely within your office infrastructure.</p>
        </div>
        <a href="/legalai"
           class="shrink-0 px-6 py-2.5 rounded border border-[#1a2d48] hover:border-[#243d60] text-[#8496b0] hover:text-white text-sm font-semibold transition-all whitespace-nowrap">
          Full Overview
        </a>
      </div>

    </div>
  </div>

</Layout>
