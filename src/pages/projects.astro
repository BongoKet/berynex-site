---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Projects — Berynex" description="Berynex project portfolio: local tech services, AI-powered tools, and legal technology.">

  <div class="pt-32 pb-24 px-6">
    <div class="max-w-7xl mx-auto">

      <!-- Header -->
      <div class="mb-16">
        <p class="text-xs text-[#4f8ef7] font-semibold tracking-widest uppercase mb-4">Portfolio</p>
        <h1 class="font-['Space_Grotesk',sans-serif] text-4xl sm:text-5xl font-bold text-white mb-4">
          Projects &amp; Ventures
        </h1>
        <p class="text-[#8892a4] max-w-xl leading-relaxed">
          A growing portfolio of technology projects spanning local services, consumer AI, and professional legal tools.
        </p>
      </div>

      <!-- Project cards -->
      <div class="grid md:grid-cols-2 gap-8 mb-16">

        <!-- Bongo's Club -->
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-8 flex flex-col">
          <div class="flex items-start justify-between mb-6">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[#4f8ef7] to-[#06b6d4] flex items-center justify-center text-2xl">🖥️</div>
            <span class="text-xs bg-[#1e2a4a] text-[#4f8ef7] px-3 py-1 rounded-full font-medium">Live</span>
          </div>
          <h2 class="font-['Space_Grotesk',sans-serif] font-bold text-white text-2xl mb-3">Bongo's Club</h2>
          <p class="text-[#8892a4] leading-relaxed mb-4 flex-1">
            Local PC repair and technical support serving Llangollen, Wrexham, Chirk, Corwen, and surrounding Denbighshire.
            No jargon. Fair prices. Honest advice. Operating on a no-fix, no-fee basis with free how-to guides for common issues.
          </p>
          <div class="border-t border-[#1e2a4a] pt-5 mt-2">
            <p class="text-xs text-[#5a6580] uppercase tracking-widest mb-3 font-medium">Services</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {["PC Repair & Diagnostics", "Virus & Malware Removal", "Upgrades & Data Transfer", "Setup & Configuration", "Free How-To Guides"].map(tag => (
                <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
            <a href="https://bongosclub.uk/" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-sm text-[#4f8ef7] hover:text-white transition-colors font-medium">
              Visit bongosclub.uk
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Torellio -->
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-8 flex flex-col">
          <div class="flex items-start justify-between mb-6">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[#7c3aed] to-[#a855f7] flex items-center justify-center text-2xl">🤖</div>
            <span class="text-xs bg-[#1e2a4a] text-[#a855f7] px-3 py-1 rounded-full font-medium">Pre-launch</span>
          </div>
          <h2 class="font-['Space_Grotesk',sans-serif] font-bold text-white text-2xl mb-3">Torellio</h2>
          <p class="text-[#8892a4] leading-relaxed mb-4 flex-1">
            An AI-powered shopping assistant browser extension that compares products across open tabs, scans rooms
            to suggest matching d&eacute;cor, and deploys four collaborative AI agents to deliver personalised buying
            recommendations. Currently in pre-launch with a waitlist open.
            Showcased at the AMD Developer Hackathon 2026.
          </p>
          <div class="border-t border-[#1e2a4a] pt-5 mt-2">
            <p class="text-xs text-[#5a6580] uppercase tracking-widest mb-3 font-medium">Features</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {["Smart Tab Comparison", "Visual Room Scanner", "Multi-Agent Research", "Price Tracking", "Personalised Picks"].map(tag => (
                <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
            <a href="https://torellio.com" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-sm text-[#a855f7] hover:text-white transition-colors font-medium">
              Visit torellio.com
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>

      </div>

      <!-- LegalAI teaser banner -->
      <div class="fade-up border border-dashed border-[#2a1f4a] bg-gradient-to-br from-[#0f1629]/40 to-[#1a0a2e]/40 rounded-2xl p-8 sm:p-10 flex flex-col sm:flex-row items-center justify-between gap-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-[#7c3aed]/5 to-transparent pointer-events-none"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl">⚖️</span>
            <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white text-xl">Berynex LegalAI</h3>
            <span class="text-xs bg-[#2a1f4a] text-[#a855f7] px-2.5 py-0.5 rounded-full">Coming Soon</span>
          </div>
          <p class="text-[#8892a4] text-sm max-w-lg">Private, on-premise AI for solicitor firms. Document drafting, case research, and client communications — all within your office walls.</p>
        </div>
        <a href="/legalai"
           class="relative z-10 shrink-0 px-7 py-3 rounded-full bg-gradient-to-r from-[#7c3aed] to-[#a855f7] text-white font-semibold text-sm hover:opacity-90 transition-opacity whitespace-nowrap">
          Full Overview &rarr;
        </a>
      </div>

    </div>
  </div>

</Layout>
