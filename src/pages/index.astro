---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Berynex — Technology. Law. Innovation.">

  <!-- HERO -->
  <section class="animated-gradient grid-overlay relative min-h-screen flex items-center justify-center overflow-hidden px-6 pt-20">
    <div class="orb absolute top-1/4 left-1/4 w-80 h-80 rounded-full opacity-10 pointer-events-none"
         style="background: radial-gradient(circle, #4f8ef7, transparent 70%)"></div>
    <div class="orb orb-2 absolute bottom-1/3 right-1/4 w-64 h-64 rounded-full opacity-8 pointer-events-none"
         style="background: radial-gradient(circle, #7c3aed, transparent 70%)"></div>
    <div class="orb orb-3 absolute top-1/2 right-1/3 w-48 h-48 rounded-full opacity-6 pointer-events-none"
         style="background: radial-gradient(circle, #06b6d4, transparent 70%)"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 border border-[#1e2a4a] bg-[#0f1629]/80 rounded-full px-4 py-1.5 text-xs text-[#8892a4] mb-8 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-[#4f8ef7] pulse-dot"></span>
        North Wales &middot; Technology &amp; Legal Innovation
      </div>

      <h1 class="font-['Space_Grotesk',sans-serif] text-5xl sm:text-7xl md:text-8xl font-bold tracking-tight mb-6 leading-none">
        <span class="text-white">BERY</span><span class="gradient-text">NEX</span>
      </h1>

      <p class="text-xl sm:text-2xl text-[#8892a4] mb-4 font-light tracking-wide">
        Technology<span class="text-[#4f8ef7]">.</span>
        Law<span class="text-[#a855f7]">.</span>
        Innovation<span class="text-[#06b6d4]">.</span>
      </p>

      <p class="text-base sm:text-lg text-[#5a6580] max-w-2xl mx-auto mb-12 leading-relaxed">
        Building intelligent tools and digital services from Llangollen, North Wales &mdash;
        from local tech support to AI-powered solutions for legal professionals.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/projects"
           class="w-full sm:w-auto px-8 py-3.5 rounded-full bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white font-semibold text-sm hover:opacity-90 transition-opacity glow-blue">
          View Projects
        </a>
        <a href="/legalai"
           class="w-full sm:w-auto px-8 py-3.5 rounded-full border border-[#1e2a4a] text-[#8892a4] font-semibold text-sm hover:border-[#4f8ef7] hover:text-white transition-all">
          LegalAI Service &rarr;
        </a>
      </div>

      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[#4a5568]">
        <span class="text-xs tracking-widest uppercase">Scroll</span>
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="py-24 px-6 border-t border-[#1e2a4a]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs text-[#4f8ef7] font-semibold tracking-widest uppercase mb-4">What We Do</p>
        <h2 class="font-['Space_Grotesk',sans-serif] text-3xl sm:text-4xl font-bold text-white">
          Technology with purpose
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-7">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#4f8ef7] to-[#06b6d4] flex items-center justify-center text-xl mb-5">🖥️</div>
          <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white mb-2">Local Tech Services</h3>
          <p class="text-[#8892a4] text-sm leading-relaxed">PC repair, virus removal, and tech support for homes and businesses across Llangollen and North Wales. Honest advice, fair prices.</p>
          <a href="/projects" class="inline-block mt-4 text-xs text-[#4f8ef7] hover:text-white transition-colors">Explore &rarr;</a>
        </div>
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-7">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#7c3aed] to-[#a855f7] flex items-center justify-center text-xl mb-5">🤖</div>
          <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white mb-2">AI-Powered Products</h3>
          <p class="text-[#8892a4] text-sm leading-relaxed">Building intelligent consumer and professional tools &mdash; from AI shopping assistants to on-premise legal AI. Practical AI that works in the real world.</p>
          <a href="/projects" class="inline-block mt-4 text-xs text-[#a855f7] hover:text-white transition-colors">Explore &rarr;</a>
        </div>
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-7">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#a855f7] to-[#ec4899] flex items-center justify-center text-xl mb-5">⚖️</div>
          <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white mb-2">Legal Technology</h3>
          <p class="text-[#8892a4] text-sm leading-relaxed">Specialist AI tools for law firms &mdash; built with an understanding of legal workflows, compliance requirements, and the realities of legal practice.</p>
          <a href="/legalai" class="inline-block mt-4 text-xs text-[#ec4899] hover:text-white transition-colors">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- LEGALAI TEASER -->
  <section class="py-24 px-6 border-t border-[#1e2a4a] relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] rounded-full opacity-5 pointer-events-none"
         style="background: radial-gradient(ellipse, #7c3aed, transparent 70%)"></div>
    <div class="max-w-5xl mx-auto relative z-10">
      <div class="fade-up border border-[#2a1f4a] bg-gradient-to-br from-[#0f1629]/80 to-[#1a0a2e]/60 rounded-3xl p-10 sm:p-14 text-center">
        <span class="inline-block text-xs bg-[#2a1f4a] text-[#a855f7] px-3 py-1 rounded-full font-semibold tracking-widest uppercase mb-6">Coming Soon</span>
        <h2 class="font-['Space_Grotesk',sans-serif] text-3xl sm:text-4xl font-bold text-white mb-4">
          Berynex <span class="gradient-text">LegalAI</span>
        </h2>
        <p class="text-[#8892a4] max-w-xl mx-auto mb-8 leading-relaxed">
          Private, on-premise AI for solicitor firms. Secure document drafting, case research,
          and client communications &mdash; with no data leaving your office.
        </p>
        <a href="/legalai"
           class="inline-block px-8 py-3.5 rounded-full bg-gradient-to-r from-[#7c3aed] to-[#a855f7] text-white font-semibold text-sm hover:opacity-90 transition-opacity">
          See the full overview &rarr;
        </a>
      </div>
    </div>
  </section>

</Layout>
