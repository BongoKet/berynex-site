---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>

  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <section id="home" class="animated-gradient grid-overlay relative min-h-screen flex items-center justify-center overflow-hidden px-6 pt-20">

    <!-- Floating background orbs -->
    <div class="orb absolute top-1/4 left-1/4 w-80 h-80 rounded-full opacity-10 pointer-events-none"
         style="background: radial-gradient(circle, #4f8ef7, transparent 70%)"></div>
    <div class="orb orb-2 absolute bottom-1/3 right-1/4 w-64 h-64 rounded-full opacity-8 pointer-events-none"
         style="background: radial-gradient(circle, #7c3aed, transparent 70%)"></div>
    <div class="orb orb-3 absolute top-1/2 right-1/3 w-48 h-48 rounded-full opacity-6 pointer-events-none"
         style="background: radial-gradient(circle, #06b6d4, transparent 70%)"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 border border-[#1e2a4a] bg-[#0f1629]/80 rounded-full px-4 py-1.5 text-xs text-[#8892a4] mb-8 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-[#4f8ef7] pulse-dot"></span>
        North Wales &middot; Technology &amp; Legal Innovation
      </div>

      <!-- Main heading -->
      <h1 class="font-['Space_Grotesk',sans-serif] text-5xl sm:text-7xl md:text-8xl font-bold tracking-tight mb-6 leading-none">
        <span class="text-white">BERY</span><span class="gradient-text">NEX</span>
      </h1>

      <p class="text-xl sm:text-2xl text-[#8892a4] mb-4 font-light tracking-wide">
        Technology<span class="text-[#4f8ef7]">.</span>
        Law<span class="text-[#a855f7]">.</span>
        Innovation<span class="text-[#06b6d4]">.</span>
      </p>

      <p class="text-base sm:text-lg text-[#5a6580] max-w-2xl mx-auto mb-12 leading-relaxed">
        Building intelligent tools and digital services from Llangollen, North Wales &mdash;
        from local tech support to AI-powered solutions for legal professionals.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#projects"
           class="w-full sm:w-auto px-8 py-3.5 rounded-full bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white font-semibold text-sm hover:opacity-90 transition-opacity glow-blue">
          View Projects
        </a>
        <a href="#legalai"
           class="w-full sm:w-auto px-8 py-3.5 rounded-full border border-[#1e2a4a] text-[#8892a4] font-semibold text-sm hover:border-[#4f8ef7] hover:text-white transition-all">
          LegalAI Service &rarr;
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[#4a5568]">
        <span class="text-xs tracking-widest uppercase">Scroll</span>
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       ABOUT
  ═══════════════════════════════════════ -->
  <section id="about" class="py-28 px-6 border-t border-[#1e2a4a]">
    <div class="max-w-7xl mx-auto">

      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Text -->
        <div>
          <p class="text-xs text-[#4f8ef7] font-semibold tracking-widest uppercase mb-4">About Berynex</p>
          <h2 class="fade-up font-['Space_Grotesk',sans-serif] text-3xl sm:text-4xl font-bold text-white mb-6 leading-tight">
            Where legal expertise meets<br/><span class="gradient-text">applied technology</span>
          </h2>
          <p class="fade-up text-[#8892a4] leading-relaxed mb-5">
            Berynex is the overarching brand behind a growing portfolio of technology projects
            built in Pontcysyllte, Llangollen. Founded by David Jones &mdash; a qualified legal
            professional with an MA in Law and a BSc in Global Leadership &mdash; Berynex sits at
            the intersection of law, technology, and practical innovation.
          </p>
          <p class="fade-up text-[#8892a4] leading-relaxed mb-8">
            With hands-on experience in property law, estate administration, business
            operations, and AI data work, the company is uniquely positioned to build tools
            that serve both everyday people and professional organisations &mdash; particularly
            in the legal sector.
          </p>
          <div class="fade-up grid grid-cols-2 gap-4">
            <div class="border border-[#1e2a4a] rounded-xl p-4 bg-[#0f1629]/50">
              <p class="text-white font-semibold text-sm">MA Law</p>
              <p class="text-[#5a6580] text-xs mt-0.5">University of Law, Liverpool</p>
            </div>
            <div class="border border-[#1e2a4a] rounded-xl p-4 bg-[#0f1629]/50">
              <p class="text-white font-semibold text-sm">BSc Leadership</p>
              <p class="text-[#5a6580] text-xs mt-0.5">De Montfort University</p>
            </div>
            <div class="border border-[#1e2a4a] rounded-xl p-4 bg-[#0f1629]/50">
              <p class="text-white font-semibold text-sm">Legal Secretary</p>
              <p class="text-[#5a6580] text-xs mt-0.5">Lynne Thornton Solicitors</p>
            </div>
            <div class="border border-[#1e2a4a] rounded-xl p-4 bg-[#0f1629]/50">
              <p class="text-white font-semibold text-sm">AI &amp; Data</p>
              <p class="text-[#5a6580] text-xs mt-0.5">Data Annotation (2025&ndash;present)</p>
            </div>
          </div>
        </div>

        <!-- Stats block -->
        <div class="fade-up grid grid-cols-2 gap-4">
          <div class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6 flex flex-col gap-2">
            <span class="font-['Space_Grotesk',sans-serif] text-4xl font-bold bg-gradient-to-br from-[#4f8ef7] to-[#7c3aed] bg-clip-text text-transparent">3+</span>
            <span class="text-[#8892a4] text-sm">Live projects</span>
          </div>
          <div class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6 flex flex-col gap-2">
            <span class="font-['Space_Grotesk',sans-serif] text-4xl font-bold bg-gradient-to-br from-[#7c3aed] to-[#a855f7] bg-clip-text text-transparent">5+</span>
            <span class="text-[#8892a4] text-sm">Years in legal services</span>
          </div>
          <div class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6 flex flex-col gap-2">
            <span class="font-['Space_Grotesk',sans-serif] text-4xl font-bold bg-gradient-to-br from-[#06b6d4] to-[#4f8ef7] bg-clip-text text-transparent">AI</span>
            <span class="text-[#8892a4] text-sm">Powered products</span>
          </div>
          <div class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6 flex flex-col gap-2">
            <span class="font-['Space_Grotesk',sans-serif] text-4xl font-bold bg-gradient-to-br from-[#a855f7] to-[#ec4899] bg-clip-text text-transparent">NW</span>
            <span class="text-[#8892a4] text-sm">North Wales based</span>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       PROJECTS
  ═══════════════════════════════════════ -->
  <section id="projects" class="py-28 px-6 border-t border-[#1e2a4a]">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-16">
        <p class="text-xs text-[#4f8ef7] font-semibold tracking-widest uppercase mb-4">Portfolio</p>
        <h2 class="font-['Space_Grotesk',sans-serif] text-3xl sm:text-4xl font-bold text-white">
          Projects &amp; Ventures
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <!-- Bongo's Club -->
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-7 flex flex-col">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#4f8ef7] to-[#06b6d4] flex items-center justify-center mb-5 text-2xl">
            🖥️
          </div>
          <div class="flex items-center gap-2 mb-3">
            <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white text-lg">Bongo's Club</h3>
            <span class="text-xs bg-[#1e2a4a] text-[#4f8ef7] px-2 py-0.5 rounded-full">Live</span>
          </div>
          <p class="text-[#8892a4] text-sm leading-relaxed flex-1 mb-5">
            Local PC repair and technical support serving Llangollen, Wrexham,
            Chirk, and surrounding Denbighshire. No jargon, fair prices, honest advice.
            Free how-to guides, virus removal, upgrades, and data recovery.
          </p>
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">PC Repair</span>
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">Virus Removal</span>
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">Upgrades</span>
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">Data Recovery</span>
          </div>
          <a href="https://bongosclub.uk/" target="_blank" rel="noopener"
             class="flex items-center gap-1.5 text-sm text-[#4f8ef7] hover:text-white transition-colors font-medium mt-auto">
            bongosclub.uk
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>

        <!-- Torellio -->
        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-7 flex flex-col">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#7c3aed] to-[#a855f7] flex items-center justify-center mb-5 text-2xl">
            🤖
          </div>
          <div class="flex items-center gap-2 mb-3">
            <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white text-lg">Torellio</h3>
            <span class="text-xs bg-[#1e2a4a] text-[#a855f7] px-2 py-0.5 rounded-full">Pre-launch</span>
          </div>
          <p class="text-[#8892a4] text-sm leading-relaxed flex-1 mb-5">
            AI-powered shopping assistant that compares products across browser tabs,
            scans rooms to suggest matching d&eacute;cor, and deploys four collaborative AI agents
            to deliver personalised buying recommendations. Showcased at AMD Developer Hackathon 2026.
          </p>
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">AI Agents</span>
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">Browser Extension</span>
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">Smart Compare</span>
            <span class="text-xs border border-[#1e2a4a] text-[#5a6580] px-2.5 py-1 rounded-full">Visual Scanner</span>
          </div>
          <a href="https://torellio.com" target="_blank" rel="noopener"
             class="flex items-center gap-1.5 text-sm text-[#a855f7] hover:text-white transition-colors font-medium mt-auto">
            torellio.com
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>

        <!-- LegalAI teaser card -->
        <div class="fade-up card-hover border border-dashed border-[#2a1f4a] bg-gradient-to-br from-[#0f1629]/40 to-[#1a0a2e]/40 rounded-2xl p-7 flex flex-col relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-[#7c3aed]/5 to-transparent pointer-events-none"></div>
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#a855f7] to-[#ec4899] flex items-center justify-center mb-5 text-2xl">
            ⚖️
          </div>
          <div class="flex items-center gap-2 mb-3">
            <h3 class="font-['Space_Grotesk',sans-serif] font-bold text-white text-lg">Berynex LegalAI</h3>
            <span class="text-xs bg-[#2a1f4a] text-[#a855f7] px-2 py-0.5 rounded-full">Coming Soon</span>
          </div>
          <p class="text-[#8892a4] text-sm leading-relaxed flex-1 mb-5">
            A private, locally-hosted LLM service purpose-built for solicitor firms.
            Secure document drafting, case research assistance, and client communication
            tools &mdash; all running on-premise with no data leaving the firm.
          </p>
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="text-xs border border-[#2a1f4a] text-[#5a6580] px-2.5 py-1 rounded-full">Local LLM</span>
            <span class="text-xs border border-[#2a1f4a] text-[#5a6580] px-2.5 py-1 rounded-full">Legal Drafting</span>
            <span class="text-xs border border-[#2a1f4a] text-[#5a6580] px-2.5 py-1 rounded-full">On-Premise</span>
            <span class="text-xs border border-[#2a1f4a] text-[#5a6580] px-2.5 py-1 rounded-full">SRA Compliant</span>
          </div>
          <a href="#legalai" class="flex items-center gap-1.5 text-sm text-[#a855f7] hover:text-white transition-colors font-medium mt-auto">
            Learn more &rarr;
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════
       LEGALAI SPOTLIGHT
  ═══════════════════════════════════════ -->
  <section id="legalai" class="py-28 px-6 border-t border-[#1e2a4a] relative overflow-hidden">

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-5 pointer-events-none"
         style="background: radial-gradient(ellipse, #7c3aed, transparent 70%)"></div>

    <div class="max-w-7xl mx-auto relative z-10">

      <div class="text-center mb-16">
        <p class="text-xs text-[#a855f7] font-semibold tracking-widest uppercase mb-4">Coming Soon</p>
        <h2 class="font-['Space_Grotesk',sans-serif] text-3xl sm:text-5xl font-bold text-white mb-5">
          AI for Local<br/><span class="gradient-text">Legal Practices</span>
        </h2>
        <p class="text-[#8892a4] max-w-2xl mx-auto text-base leading-relaxed">
          Berynex LegalAI is an on-premise AI assistant designed specifically for small and
          mid-size solicitor firms &mdash; backed by real legal knowledge, built with privacy first.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-16">

        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6">
          <div class="text-3xl mb-4">🔒</div>
          <h3 class="font-semibold text-white mb-2 text-base">100% On-Premise</h3>
          <p class="text-[#5a6580] text-sm leading-relaxed">All AI processing happens on hardware within the firm. No data ever leaves the office. Full compliance with SRA and GDPR obligations.</p>
        </div>

        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6">
          <div class="text-3xl mb-4">📄</div>
          <h3 class="font-semibold text-white mb-2 text-base">Document Drafting</h3>
          <p class="text-[#5a6580] text-sm leading-relaxed">AI-assisted drafting of standard legal documents &mdash; conveyancing letters, client care packs, probate correspondence &mdash; in seconds.</p>
        </div>

        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6">
          <div class="text-3xl mb-4">🔍</div>
          <h3 class="font-semibold text-white mb-2 text-base">Case Research</h3>
          <p class="text-[#5a6580] text-sm leading-relaxed">Query your case files and precedent library in plain English. Get relevant clauses, precedents, and risk flags instantly.</p>
        </div>

        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6">
          <div class="text-3xl mb-4">💬</div>
          <h3 class="font-semibold text-white mb-2 text-base">Client Comms</h3>
          <p class="text-[#5a6580] text-sm leading-relaxed">Generate professional, accurate client update letters and emails. Maintain consistent tone across all fee earner communication.</p>
        </div>

        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6">
          <div class="text-3xl mb-4">🧠</div>
          <h3 class="font-semibold text-white mb-2 text-base">Local LLM Engine</h3>
          <p class="text-[#5a6580] text-sm leading-relaxed">Powered by open-weight models fine-tuned on legal language &mdash; delivering GPT-4 quality results without cloud exposure.</p>
        </div>

        <div class="fade-up card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-6">
          <div class="text-3xl mb-4">🏛️</div>
          <h3 class="font-semibold text-white mb-2 text-base">Built by a Legal Pro</h3>
          <p class="text-[#5a6580] text-sm leading-relaxed">Designed by someone with hands-on conveyancing, probate, and client advisory experience &mdash; not just an engineer guessing at legal workflows.</p>
        </div>

      </div>

      <!-- CTA banner -->
      <div class="fade-up border border-[#2a1f4a] bg-gradient-to-r from-[#1a0a2e]/60 to-[#0f1629]/60 rounded-2xl p-8 sm:p-12 text-center backdrop-blur-sm">
        <h3 class="font-['Space_Grotesk',sans-serif] text-2xl sm:text-3xl font-bold text-white mb-3">
          Interested in early access?
        </h3>
        <p class="text-[#8892a4] mb-8 max-w-xl mx-auto text-sm leading-relaxed">
          Berynex LegalAI is currently in development. If you run a solicitor firm in North Wales
          or the wider UK and want to explore a pilot, get in touch.
        </p>
        <a href="#contact"
           class="inline-block px-10 py-3.5 rounded-full bg-gradient-to-r from-[#7c3aed] to-[#a855f7] text-white font-semibold text-sm hover:opacity-90 transition-opacity">
          Register Interest
        </a>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════
       CONTACT
  ═══════════════════════════════════════ -->
  <section id="contact" class="py-28 px-6 border-t border-[#1e2a4a]">
    <div class="max-w-3xl mx-auto text-center">

      <p class="text-xs text-[#4f8ef7] font-semibold tracking-widest uppercase mb-4">Get in Touch</p>
      <h2 class="fade-up font-['Space_Grotesk',sans-serif] text-3xl sm:text-4xl font-bold text-white mb-5">
        Let's build something
      </h2>
      <p class="fade-up text-[#8892a4] mb-12 leading-relaxed">
        Whether you're a solicitor firm exploring AI, a local business needing tech support,
        or a collaborator with an idea &mdash; reach out.
      </p>

      <div class="fade-up grid sm:grid-cols-3 gap-4 mb-12">
        <a href="mailto:davidjonesuk1997@gmail.com"
           class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-xl p-5 flex flex-col items-center gap-2 group">
          <span class="text-2xl">✉️</span>
          <span class="text-xs text-[#8892a4] group-hover:text-white transition-colors">Email</span>
          <span class="text-xs text-[#5a6580] break-all">davidjonesuk1997@gmail.com</span>
        </a>
        <a href="https://linkedin.com/in/dave7152" target="_blank" rel="noopener"
           class="card-hover border border-[#1e2a4a] bg-[#0f1629]/60 rounded-xl p-5 flex flex-col items-center gap-2 group">
          <span class="text-2xl">💼</span>
          <span class="text-xs text-[#8892a4] group-hover:text-white transition-colors">LinkedIn</span>
          <span class="text-xs text-[#5a6580]">linkedin.com/in/dave7152</span>
        </a>
        <div class="border border-[#1e2a4a] bg-[#0f1629]/60 rounded-xl p-5 flex flex-col items-center gap-2">
          <span class="text-2xl">📍</span>
          <span class="text-xs text-[#8892a4]">Location</span>
          <span class="text-xs text-[#5a6580]">Llangollen, North Wales</span>
        </div>
      </div>

      <!-- Contact form — replace YOUR-FORM-ID with Formspree ID after signup -->
      <form class="fade-up border border-[#1e2a4a] bg-[#0f1629]/60 rounded-2xl p-8 text-left backdrop-blur-sm"
            action="https://formspree.io/f/YOUR-FORM-ID" method="POST">
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Name</label>
            <input type="text" name="name" required
                   class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white placeholder-[#4a5568] focus:outline-none focus:border-[#4f8ef7] transition-colors"
                   placeholder="Your name" />
          </div>
          <div>
            <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Email</label>
            <input type="email" name="email" required
                   class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white placeholder-[#4a5568] focus:outline-none focus:border-[#4f8ef7] transition-colors"
                   placeholder="you@example.com" />
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Subject</label>
          <select name="subject"
                  class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-[#4f8ef7] transition-colors">
            <option value="legalai">LegalAI &mdash; Early Access / Pilot</option>
            <option value="tech">Tech Support / PC Repair</option>
            <option value="torellio">Torellio &mdash; Waitlist / Feedback</option>
            <option value="other">General Enquiry</option>
          </select>
        </div>
        <div class="mb-6">
          <label class="block text-xs text-[#8892a4] mb-1.5 font-medium">Message</label>
          <textarea name="message" required rows="4"
                    class="w-full bg-[#080c18] border border-[#1e2a4a] rounded-xl px-4 py-2.5 text-sm text-white placeholder-[#4a5568] focus:outline-none focus:border-[#4f8ef7] transition-colors resize-none"
                    placeholder="Tell me what you're working on..."></textarea>
        </div>
        <button type="submit"
                class="w-full py-3.5 rounded-xl bg-gradient-to-r from-[#4f8ef7] to-[#7c3aed] text-white font-semibold text-sm hover:opacity-90 transition-opacity">
          Send Message
        </button>
      </form>

    </div>
  </section>

</Layout>
